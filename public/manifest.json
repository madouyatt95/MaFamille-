{
  "name": "MyFamily+",
  "short_name": "MyFamily+",
  "description": "Système d'exploitation complet de la famille (Finances, Agenda, Santé, École, IA).",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#07111F",
  "theme_color": "#07111F",
  "orientation": "portrait-primary",
  "categories": ["utilities", "productivity", "finance"],
  "shortcuts": [
    {
      "name": "Ajouter une Dépense",
      "short_name": "+ Dépense",
      "description": "Ajouter rapidement une dépense à votre foyer",
      "url": "/?tab=finances&action=add-expense",
      "icons": [
        {
          "src": "/favicon.svg",
          "sizes": "192x192",
          "type": "image/svg+xml"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?action=share-receipt",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "receipt",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
